---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { SITE_TITLE, CATEGORIES } from '../../consts';

const allCategories = ['tous', ...Object.keys(CATEGORIES)] as const;

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={`Articles | ${SITE_TITLE}`} description="Tous les articles Pickleball Mania : actualités, tests, conseils et guides." />
  </head>
  <body class="bg-slate-50 text-slate-900">
    <Header />
    <main class="max-w-6xl mx-auto px-4 py-12">
      <h1 class="text-3xl font-bold mb-8 text-center">Tous les articles</h1>

      <!-- Category tabs -->
      <div class="flex flex-wrap justify-center gap-2 mb-10">
        {allCategories.map(cat => (
          <a
            href={cat === 'tous' ? '/blog/' : `/categorie/${cat}/`}
            class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${
              cat === 'tous'
                ? 'bg-primary-600 text-white'
                : 'bg-white text-slate-600 border border-slate-200 hover:border-primary-300 hover:text-primary-700'
            }`}
          >
            {cat === 'tous' ? 'Tous' : CATEGORIES[cat as keyof typeof CATEGORIES]?.label ?? cat}
          </a>
        ))}
      </div>

      <!-- Articles grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <ArticleCard post={post} />
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
