---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CATEGORIES, type CategoryKey } from '../consts';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-slate-50 text-slate-900">
    <Header />
    <main>

      <!-- Hero -->
      <section class="bg-gradient-to-br from-primary-700 via-primary-600 to-primary-800 text-white py-20">
        <div class="max-w-4xl mx-auto px-4 text-center">
          <p class="text-primary-200 text-sm font-medium mb-4 uppercase tracking-wide">
            Le sport n&deg;1 en croissance mondiale
          </p>
          <h1 class="text-4xl md:text-5xl font-bold mb-4">
            Pickleball Mania
          </h1>
          <p class="text-xl text-primary-100 mb-10 max-w-2xl mx-auto">
            Actualités, guides, tests et conseils pour les joueurs de pickleball francophones.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="/blog/"
              class="bg-white text-primary-700 font-bold py-3 px-8 rounded-xl hover:bg-primary-50 transition-colors"
            >
              Tous les articles &rarr;
            </a>
            <a
              href="/categorie/debuter/"
              class="bg-primary-500/30 text-white font-bold py-3 px-8 rounded-xl border border-primary-400/40 hover:bg-primary-500/50 transition-colors"
            >
              Guide débutant
            </a>
          </div>
        </div>
      </section>

      <!-- Categories -->
      <section class="max-w-6xl mx-auto px-4 -mt-8">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
          {Object.entries(CATEGORIES).map(([key, cat]) => (
            <a
              href={key === 'equipement' ? '/equipement/' : `/categorie/${key}/`}
              class="bg-white rounded-xl p-4 text-center border border-slate-200 hover:border-primary-300 hover:shadow-md transition-all"
            >
              <div class={`w-3 h-3 rounded-full ${cat.colorDot} mx-auto mb-2`}></div>
              <span class="text-sm font-medium text-slate-700">{cat.label}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Latest articles -->
      <section class="max-w-6xl mx-auto px-4 py-16">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold">Derniers articles</h2>
          <a href="/blog/" class="text-primary-600 hover:text-primary-700 text-sm font-medium transition-colors">
            Voir tout &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <ArticleCard post={post} />
          ))}
        </div>
      </section>

      <!-- Equipment section -->
      <section class="bg-white border-y border-slate-200 py-16">
        <div class="max-w-6xl mx-auto px-4">
          <h2 class="text-2xl font-bold mb-8 text-center">Équipement populaire</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <a href="/equipement/" class="group p-6 rounded-2xl text-center border border-slate-200 hover:border-primary-300 hover:shadow-md transition-all">
              <div class="text-4xl mb-3">🏓</div>
              <h3 class="text-lg font-bold mb-2 text-slate-900 group-hover:text-primary-700 transition-colors">Raquettes</h3>
              <p class="text-slate-500 text-sm">Les meilleures raquettes testées et approuvées.</p>
            </a>
            <a href="/equipement/" class="group p-6 rounded-2xl text-center border border-slate-200 hover:border-primary-300 hover:shadow-md transition-all">
              <div class="text-4xl mb-3">👟</div>
              <h3 class="text-lg font-bold mb-2 text-slate-900 group-hover:text-primary-700 transition-colors">Chaussures</h3>
              <p class="text-slate-500 text-sm">Chaussures indoor et outdoor pour le pickleball.</p>
            </a>
            <a href="/equipement/" class="group p-6 rounded-2xl text-center border border-slate-200 hover:border-primary-300 hover:shadow-md transition-all">
              <div class="text-4xl mb-3">🎾</div>
              <h3 class="text-lg font-bold mb-2 text-slate-900 group-hover:text-primary-700 transition-colors">Balles & Filets</h3>
              <p class="text-slate-500 text-sm">Tout l'équipement pour jouer partout.</p>
            </a>
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>
