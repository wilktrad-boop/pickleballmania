---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE_TITLE, CATEGORIES, type CategoryKey } from '../../consts';

export function getStaticPaths() {
  return Object.keys(CATEGORIES).map(key => ({
    params: { category: key },
  }));
}

const { category } = Astro.params;
const cat = CATEGORIES[category as CategoryKey];
const label = cat?.label ?? category;
const description = cat?.description ?? `Articles ${label} sur Pickleball Mania`;

const posts = (await getCollection('blog'))
  .filter(p => p.data.category === category && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={`${label} | ${SITE_TITLE}`} description={description} />
  </head>
  <body class="bg-slate-50 text-slate-900">
    <Header />
    <main class="max-w-6xl mx-auto px-4 py-12">
      <Breadcrumbs items={[{ label }]} />
      <h1 class="text-3xl font-bold mb-3">{label}</h1>
      <p class="text-slate-500 mb-10 max-w-2xl">{description}</p>

      {posts.length === 0 ? (
        <p class="text-center text-slate-400 py-12">Aucun article dans cette catégorie pour le moment.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map(post => (
            <ArticleCard post={post} />
          ))}
        </div>
      )}
    </main>
    <Footer />
  </body>
</html>
