---
import { SITE_TITLE, CATEGORIES } from '../consts';
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/blog/', label: 'Articles' },
  { href: '/categorie/tests/', label: CATEGORIES.tests.label },
  { href: '/categorie/conseils/', label: CATEGORIES.conseils.label },
  { href: '/equipement/', label: CATEGORIES.equipement.label },
  { href: '/categorie/debuter/', label: CATEGORIES.debuter.label },
];
---

<header class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-primary-700 hover:text-primary-600 transition-colors">
      {SITE_TITLE}
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
            currentPath === link.href
              ? 'bg-primary-50 text-primary-700'
              : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors text-slate-600"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-white border-t border-slate-200">
    <div class="px-4 py-2 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`block px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
            currentPath === link.href
              ? 'bg-primary-50 text-primary-700'
              : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn?.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
